                        },
                        "children": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "field": {
                                "type": "string"
                              },
                              "value": {
                                "type": "string"
                              },
                              "operator": {
                                "type": "string",
                                "enum": [
                                  "LARGER",
                                  "SMALLER",
                                  "LARGER_EQUAL",
                                  "SMALLER_EQUAL",
                                  "EQUAL",
                                  "NOT_EQUAL",
                                  "ALL_IN",
                                  "ANY_IN",
                                  "NOT_IN",
                                  "BETWEEN",
                                  "NOT_BETWEEN",
                                  "LIKE",
                                  "NOT_LIKE",
                                  "IN"
                                ]
                              },
                              "on": {
                                "type": "string",
                                "enum": [
                                  "subscriber",
                                  "payload"
                                ]
                              }
                            },
                            "required": [
                              "field",
                              "value",
                              "operator",
                              "on"
