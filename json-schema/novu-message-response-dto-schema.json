            "draft": {
              "type": "boolean"
            },
            "preferenceSettings": {
              "type": "object",
              "properties": {
                "email": {
                  "type": "boolean",
                  "description": "Email channel preference",
                  "example": true
                },
                "sms": {
                  "type": "boolean",
                  "description": "SMS channel preference",
                  "example": false
                },
                "in_app": {
                  "type": "boolean",
                  "description": "In-app channel preference",
                  "example": true
                },
                "chat": {
                  "type": "boolean",
                  "description": "Chat channel preference",
                  "example": false
                },
                "push": {
                  "type": "boolean",
                  "description": "Push notification channel preference",
                  "example": true
                }
              }
            },
            "critical": {
              "type": "boolean"
            },
            "tags": {
              "type": "array",
